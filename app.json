{
  "expo": {
    "name": "Watasu",
    "slug": "watasu",
    "scheme": "watasu",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAFAF9"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.patrickminot.watasu",
      "buildNumber": "3",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Watasu uses your approximate location to show nearby items from community parents."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FAFAF9"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.patrickminot.watasu",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#C084FC"
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "Watasu reads your contacts to find friends already on the app. Contacts are never stored."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Watasu uses your approximate location to show nearby items from community parents.",
          "isAndroidBackgroundLocationEnabled": false
        }
      ]
    ]
  }
}
