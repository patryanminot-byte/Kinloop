{
  "expo": {
    "name": "Watasu",
    "slug": "watasu",
    "scheme": "watasu",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAFAF9"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.patrickminot.watasu",
      "buildNumber": "8",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSContactsUsageDescription": "Watasu checks which of your contacts are already on the app by comparing phone number hashes. Your contacts are never uploaded, stored, or shared.",
        "NSLocationWhenInUseUsageDescription": "Watasu uses your approximate location to show how far away nearby items are. We never track your precise location.",
        "NSCameraUsageDescription": "Watasu uses your camera to take photos of items you want to share. Photos are optional.",
        "NSPhotoLibraryUsageDescription": "Watasu accesses your photo library so you can add photos to item listings. Photos are optional.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FAFAF9"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.patrickminot.watasu",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#C084FC"
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "Watasu reads your contacts to find friends already on the app. Contacts are never stored."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Watasu uses your approximate location to show nearby items from other users.",
          "isAndroidBackgroundLocationEnabled": false
        }
      ],
      "expo-web-browser",
      "expo-apple-authentication",
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.patrickminot.watasu",
          "enableGooglePay": false
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "60b629d7-9b31-4c04-b45c-3125e2ef3b21"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/60b629d7-9b31-4c04-b45c-3125e2ef3b21"
    }
  }
}
